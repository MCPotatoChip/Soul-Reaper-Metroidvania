      c.fillStyle='#181818';c.fillRect(3,28+ll,8,12+ll);c.fillRect(13,28+rl,8,12+rl);
      c.fillStyle='#111';c.fillRect(3,39+ll,9,2);c.fillRect(13,39+rl,9,2);
