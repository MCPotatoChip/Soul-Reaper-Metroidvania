// ─────────────────────────────── PORTRAIT DRAWING ─────────────────────────────
function drawPortrait(type){
  PX.clearRect(0,0,56,56);PX.fillStyle='#1a1028';PX.fillRect(0,0,56,56);
  switch(type){
    case 'urahara':case 'urahara2':case 'urahara3':
      PX.fillStyle='#f5d0a8';PX.fillRect(18,22,20,14);
